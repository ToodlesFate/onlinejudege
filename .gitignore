# Build directories
build/
cmake-build-*/
out/
bin/

# CMake / Ninja generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/
build.ninja
.ninja_deps
.ninja_log
rules.ninja
Makefile

# Object / library files
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# IDE / Editor
.vscode/
.vs/
.idea/
*.code-workspace
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Env / secrets
.env
.env.local
*.pem
credentials.json
secrets.yaml

# Database dumps
*.sql.bak
*.dump

# Test / coverage
*.gcov
*.gcda
*.gcno
coverage/
Testing/

# Project notes / interview transcripts (not for the repo)
a.md

# Local-fetched third-party sources (used by OJ_LOCAL_DEPS_DIR in CMake)
# Only the five expected deps are listed; do not commit the actual source.
backend/.local-deps/cpp-httplib/
backend/.local-deps/spdlog/
backend/.local-deps/jwt-cpp/
backend/.local-deps/doctest/
backend/.local-deps/json/
# Generic fallback so a future dep doesn't accidentally get committed
backend/.local-deps/*/
!backend/.local-deps/.keep
